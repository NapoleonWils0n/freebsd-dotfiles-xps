#===============================================================================
# FILE: Makefile
# Project: ffmpeg
#===============================================================================


#===============================================================================
# PHONY
#===============================================================================

.PHONY: all clean


#===============================================================================
# commands
#===============================================================================

# compose.yaml
DIR_PATH	:= ${HOME}/podman/freebsd-cuda/containers/scripts/ffmpeg/
COMPOSE_FILE  	:= ${HOME}/podman/freebsd-cuda/containers/scripts/ffmpeg/compose.yaml
ENV_FILE  	:= ${HOME}/podman/freebsd-cuda/containers/scripts/ffmpeg/.env
COMPOSE_CMD	:= doas podman-compose 
ENTER_CONTAINER := doas podman exec -it -u ${USER} ffmpeg-scripts /bin/bash

# compose up and down
COMPOSE_UP	:= $(COMPOSE_CMD) --env-file $(ENV_FILE) -f $(COMPOSE_FILE) up -d
COMPOSE_DOWN	:= $(COMPOSE_CMD) -f $(COMPOSE_FILE) down


#===============================================================================
# default target
#===============================================================================

all: enter


#===============================================================================
# compose up
#===============================================================================

container: 
	$(COMPOSE_UP)


#===============================================================================
# change directory
#===============================================================================

changedir: container
	cd $(DIR_PATH)


#===============================================================================
# enter the container
#===============================================================================

enter: changedir
	$(ENTER_CONTAINER)


#===============================================================================
# clean 
#===============================================================================

clean:
	$(COMPOSE_DOWN)
