#===============================================================================
# FILE: Makefile
# Project: Kokoro
#===============================================================================


#===============================================================================
# PHONY
#===============================================================================

.PHONY: all clean


#===============================================================================
# commands
#===============================================================================

# compose.yaml
COMPOSE_FILE  	:= ${HOME}/podman/freebsd-cuda/containers/python/kokoro-onnx/compose.yaml
COMPOSE_CMD	:= doas podman-compose -f
ENV_FILE  	:= ${HOME}/podman/freebsd-cuda/containers/python/kokoro-onnx/.env
JAIL_NAME	:= kokoro-onnx
STARTUP_SCRIPT	:= kokoro-api
COMPOSE_DOWN	:= $(COMPOSE_CMD) $(COMPOSE_FILE) down


#===============================================================================
# default target
#===============================================================================

all: container


#===============================================================================
# compose up
#===============================================================================

container: 
	wrapper-freebsd -j $(JAIL_NAME) -a $(STARTUP_SCRIPT) -c $(COMPOSE_FILE) -e $(ENV_FILE)


#===============================================================================
# clean 
#===============================================================================

clean:
	$(COMPOSE_DOWN)
