#===============================================================================
# FILE: Makefile
# Project: Searxng
#===============================================================================


#===============================================================================
# PHONY
#===============================================================================

.PHONY: all clean


#===============================================================================
# commands
#===============================================================================

# compose.yaml
COMPOSE_FILE  	:= ${HOME}/podman/searxng/compose.yaml
COMPOSE_CMD	:= doas podman-compose -f
COMPOSE_UP	:= $(COMPOSE_CMD) $(COMPOSE_FILE) up -d
COMPOSE_DOWN	:= $(COMPOSE_CMD) $(COMPOSE_FILE) down


#===============================================================================
# default target
#===============================================================================

all: container


#===============================================================================
# compose up
#===============================================================================

container: 
	$(COMPOSE_UP)

#===============================================================================
# clean 
#===============================================================================

clean:
	$(COMPOSE_DOWN)
